TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_BOT_USERNAME=creative_bot
TELEGRAM_SECRET_KEY=your_secret_key_here

DB_NAME=creative_bot
DB_USER=creative_user
DB_PASSWORD=dev_password

STORAGE_DRIVER=s3

# Local dev (docker-compose minio):
S3_ENDPOINT=http://minio:9000
S3_PUBLIC_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=creatives
S3_REGION=us-east-1

# Supabase Storage (production):
# STORAGE_DRIVER=s3
# S3_ENDPOINT=https://<project-ref>.storage.supabase.co/storage/v1/s3
# S3_PUBLIC_URL=https://<project-ref>.supabase.co/storage/v1/object/public
# S3_ACCESS_KEY=<from Supabase Dashboard → Storage → S3 Access Keys>
# S3_SECRET_KEY=<from Supabase Dashboard → Storage → S3 Access Keys>
# S3_BUCKET=creatives
# S3_REGION=<project region from Supabase S3 settings, e.g. eu-central-1>

API_URL=http://localhost:3000
MINI_APP_URL=http://localhost:3001
DOMAIN=example.com
LETSENCRYPT_EMAIL=admin@example.com

JWT_SECRET=dev-secret-key-change-in-production

NODE_ENV=development
LOG_LEVEL=info
SENTRY_DSN=
SENTRY_RELEASE=0.1.0

BACKUP_RETENTION_DAYS=30
BACKUP_MAX_AGE_SECONDS=93600
BACKUP_HOST_PATH=./backups
BACKUP_OFFSITE_HOST_PATH=./backups-offsite
BACKUP_OFFSITE_DIR=/offsite
DOWNLOAD_LOG_RETENTION_DAYS=365
OPS_JOB_INTERVAL_SECONDS=3600
SIGNED_PREVIEW_URL_TTL_SECONDS=900
SIGNED_DOWNLOAD_URL_TTL_SECONDS=900

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change-me
REDIS_PASSWORD=
